  "keyFeatures": [
    "Role-based access control with three roles: patient, doctor, and administrator",
    "Patient appointment booking with real-time slot availability",
    "Clinical records management with diagnosis, treatment plans, and medication prescriptions (JSONB)",
    "Doctor schedule management with 40-minute time slot engine and break support",
    "Medication catalog with OTC/Rx classification and specialty filtering",
    "Medical specialties catalog with doctor listings per specialty",
    "Admin dashboard with platform-wide statistics and management tools",
    "Email verification and password recovery via Gmail API / Nodemailer",
    "PDF generation and viewing for clinical histories and prescriptions",
    "PostgreSQL triggers for immutable audit logs on all appointment changes",
    "Deployment on Railway with separate frontend (React/Vite) and backend (Node.js/Express) services"
  ],
